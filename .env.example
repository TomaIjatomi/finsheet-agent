# Copy this file to .env and fill in your values. .env is gitignored.

# Required: your GCP project ID
GCP_PROJECT_ID=finsheet-agent-dev

# Region — "global" is the production endpoint for Gemini 2.5 Pro
GCP_REGION=global

# Model IDs — defaults to 2.5 Pro (GA, higher quota, production-realistic).
# Switch to gemini-3.1-pro-preview only if you want direct paper comparability
# AND have approved quota for preview models.
GEMINI_PRO_MODEL=gemini-2.5-pro

# Used by the Tier-3 LLM judge in bench/verifier.py. Drop if Flash is no longer
# referenced anywhere (run: grep -rn GEMINI_FLASH_MODEL src/ bench/ scripts/).
GEMINI_FLASH_MODEL=gemini-flash-latest

# Optional: observability
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
